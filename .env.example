# Google Tag Manager
# Set your GTM Container ID (e.g. GTM-XXXXXXX) to enable analytics tracking
PUBLIC_GTM_ID=

# Notion CMS
# 1. Create an internal integration at https://www.notion.so/my-integrations
# 2. Share each database with the integration.
# 3. Copy each database ID from its URL.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PROJECTS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_EXPERIMENTS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional notes/blog database. Legacy NOTION_API_KEY is still accepted by server code.
NOTION_BLOG_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
